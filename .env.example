# Port to run the server on (default: 3000)
PORT=3000

# Max simultaneous origin lanes (browsers).
# 0 = one lane per origin, all simultaneous (recommended for local, 8GB+ RAM).
# 2 = safe for 512MB-1GB VPS.
MAX_PARALLEL=0

# Max date pairs searched simultaneously within each origin lane.
# Default: 2 (two browsers per origin at once — doubles speed).
# Set to 1 on low-RAM servers (512MB VPS).
PAIRS_PARALLEL_PER_LANE=2
